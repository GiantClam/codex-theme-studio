{
  "name": "codex-skin-archive",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build --webpack",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --webpack",
    "deploy": "npm run deploy:database && npm run deploy:app",
    "deploy:app": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "deploy:database": "node scripts/deploy-database.mjs",
    "generate:types": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts && payload generate:types",
    "generate:importmap": "payload generate:importmap",
    "lint": "next lint",
    "payload": "payload",
    "test": "node --test test/*.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@payloadcms/db-d1-sqlite": "3.86.0",
    "@payloadcms/next": "3.86.0",
    "@payloadcms/richtext-lexical": "3.86.0",
    "@payloadcms/storage-r2": "3.86.0",
    "cross-env": "^10.1.0",
    "graphql": "^16.13.0",
    "next": "16.2.10",
    "payload": "3.86.0",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "typescript": "^6.0.0",
    "wrangler": "^4.67.0"
  },
  "engines": {
    "node": ">=24"
  }
}
